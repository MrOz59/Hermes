do_setcap() {
    setcap cap_sys_admin+p /usr/bin/apollo
}

do_udev_reload() {
    udevadm control --reload-rules
    udevadm trigger --property-match=DEVNAME=/dev/uinput
    udevadm trigger --property-match=DEVNAME=/dev/uhid
    modprobe uinput || true
    modprobe uhid || true
}

fix_asset_permissions() {
    # pacman preserves existing directory modes on upgrade. Keep packaged
    # assets system-owned and non-writable after replacing older local builds.
    chown -R root:root /usr/share/apollo
    find /usr/share/apollo -type d -exec chmod 755 {} +
    find /usr/share/apollo -type f -exec chmod 644 {} +
}

load_evdi() {
    # Carregar módulo EVDI para virtual display
    echo "options evdi initial_device_count=1" > /etc/modprobe.d/apollo-evdi.conf
    modprobe -r evdi 2>/dev/null || true
    if ! modprobe evdi; then
        echo "==> AVISO: o módulo EVDI não pôde ser carregado." >&2
        echo "==> Displays virtuais permanecerão desativados até o EVDI ser corrigido." >&2
        echo "==> Execute: dkms status" >&2
        echo "==> Depois de atualizar um EVDI compatível com seu kernel, execute:" >&2
        echo "==>   sudo dkms autoinstall -k \$(uname -r)" >&2
        echo "==>   sudo modprobe evdi" >&2
        return 1
    fi
    
    # Adicionar ao carregamento automático no boot
    if [ ! -f /etc/modules-load.d/evdi.conf ]; then
        echo "evdi" > /etc/modules-load.d/evdi.conf
    fi
}

post_install() {
    do_setcap
    do_udev_reload
    fix_asset_permissions
    if ! load_evdi; then
        echo "==> Hermes foi instalado, mas o display virtual EVDI não está pronto." >&2
        echo "==> Abra Audio/Video no Hermes para ver o diagnóstico e os próximos passos." >&2
        return 0
    fi

    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║          Hermes instalado com sucesso!                   ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║  • Virtual display (EVDI) configurado automaticamente    ║"
    echo "║  • Capabilities para KMS capture configuradas            ║"
    echo "║                                                          ║"
    echo "║  Execute 'apollo' para iniciar o servidor                ║"
    echo "║  Acesse https://localhost:47990 para configurar          ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
}

post_upgrade() {
    do_setcap
    do_udev_reload
    fix_asset_permissions
    if ! load_evdi; then
        echo "==> Hermes foi atualizado, mas o display virtual EVDI não está pronto." >&2
        echo "==> Abra Audio/Video no Hermes para ver o diagnóstico e os próximos passos." >&2
        return 0
    fi

    echo ""
    echo "==> Hermes atualizado com sucesso!"
    echo ""
}

pre_remove() {
    # Remover configuração de autoload do evdi se foi criada por nós
    if [ -f /etc/modules-load.d/evdi.conf ]; then
        rm -f /etc/modules-load.d/evdi.conf
    fi
    rm -f /etc/modprobe.d/apollo-evdi.conf
}
